## Shared URLs
APP_FRONTEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
OAUTH2_REDIRECT_URL=http://localhost:3000/auth/callback

## Backend Database
DB_URL=jdbc:mysql://localhost:3306/smart_campus_db
DB_USERNAME=smartcampus
DB_PASSWORD=smartcampus
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
JPA_SHOW_SQL=false
UPLOAD_DIR=./uploads

## Google OAuth2 (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Password reset (optional demo — never enable in public production)
# When true, POST /api/auth/forgot-password logs the reset link in backend output (demo mode only).
AUTH_RESET_DEMO_LINK=false

## SMTP settings (for real email delivery when enabled in backend)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

## Frontend .env values
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_BACKEND_BASE_URL=http://localhost:8080

