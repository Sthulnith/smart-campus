## Shared URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
OAUTH2_REDIRECT_URL=http://localhost:3000/auth/callback

## Backend Database
DB_URL=jdbc:mysql://localhost:3306/smart_campus_db
DB_USERNAME=smartcampus
DB_PASSWORD=smartcampus
HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
UPLOAD_DIR=./uploads

## Google OAuth2 (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Password reset (optional demo — never enable in public production)
# When true, POST /api/auth/forgot-password includes resetLink in JSON and logs the link (no SMTP required).
AUTH_RESET_DEMO_LINK=false

## Frontend .env values
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_BACKEND_BASE_URL=http://localhost:8080

